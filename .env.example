# =============================================================================
# Variables de Entorno - Perfil recomendado para producción empresarial
# =============================================================================
# Copiar este archivo como .env.local y personalizar valores.

# === MODO DE EJECUCIÓN ===
# desarrollo | produccion
TICKETS_MODE=produccion
# Si está en 1, el servidor falla al iniciar si detecta configuración insegura.
TICKETS_STRICT_SECURITY=1

# === SERVIDOR TICKETS (HTTP/WS) ===
# Usa IP fija del servidor en la LAN empresarial, evita 0.0.0.0 en producción.
TICKETS_HTTP_BIND_HOST=192.168.1.50
TICKETS_WS_BIND_HOST=192.168.1.50
TICKETS_HTTP_REQUIRE_API_KEY=1
TICKETS_HTTP_API_KEY_HEADER=X-Tickets-Key
# Recomendado >= 24 caracteres aleatorios.
TICKETS_HTTP_API_KEY=CAMBIAR_POR_API_KEY_LARGA_Y_UNICA_2026
TICKETS_HTTP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optimización de operación
TICKETS_DISCOVERY_CACHE_TTL=30
TICKETS_DISCOVERY_MAX_WORKERS=24
TICKETS_EQUIPO_DB_SYNC_MIN_INTERVAL=15

# === SERVIDOR DE LICENCIAS ===
TICKETS_LICENSE_HOST=192.168.1.50
TICKETS_LICENSE_PORT=8787
# Recomendado >= 24 caracteres aleatorios.
TICKETS_LICENSE_ADMIN_KEY=CAMBIAR_POR_ADMIN_KEY_LARGA_Y_UNICA_2026
TICKETS_LICENSE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TICKETS_LICENSE_VALIDATE_RATE_MAX=60
TICKETS_LICENSE_VALIDATE_RATE_WINDOW=60
TICKETS_LICENSE_MAX_JSON_VALIDATE=65536
TICKETS_LICENSE_MAX_JSON_ADMIN=32768
TICKETS_LICENSE_MAX_FORM_ADMIN=16384

# === LOGGING ===
# DEBUG, INFO, WARNING, ERROR, CRITICAL
TICKETS_LOG_LEVEL=INFO
